# RentMaster frontend (rent-master-pwa-ui) — copy to .env.local and fill in.
# NEXT_PUBLIC_* values are inlined at BUILD time — rebuild if they change.

# Deployed backend base URL (rent-master-pwa). Defaults to http://localhost:3000 if unset.
NEXT_PUBLIC_API_BASE=https://your-backend-domain.com

# Web Push public VAPID key — MUST match the backend's NEXT_PUBLIC_VAPID_PUBLIC_KEY.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
